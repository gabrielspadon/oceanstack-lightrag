# Project: ships — vessel/ship knowledge graph populated by the OceanStack derive
# pipeline (bridge-fed via HTTP insert_texts, not the inotify file-watcher).
# Isolated from the code KG: distinct workspace + port, sharing the lightrag DB
# (workspace-column isolation). NetworkX graphml lands under WORKING_DIR/WORKSPACE,
# so the shared rag-storage root keeps the two graphs in separate subdirectories.
WORKSPACE=oceanstack_ships
PORT=9622
WORKING_DIR=/fast-array/lightrag/rag-storage
INPUT_DIR=/fast-array/lightrag/inputs-ships
POSTGRES_DATABASE=lightrag
LLM_MODEL=gemma4:26b-a4b-it-q4_K_M
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIM=1024
